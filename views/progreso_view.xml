<odoo>
  <record id="progresos_list_action" model="ir.actions.act_window">
    <field name="name">Progresos</field>
    <field name="res_model">upolang.progreso</field>
    <field name="view_mode">list,form</field>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">Crear el primer progreso</p>
    </field>
  </record>

  <record id="view_progreso_list" model="ir.ui.view">
    <field name="name">upolang.progreso.list</field>
    <field name="model">upolang.progreso</field>
    <field name="arch" type="xml">
      <tree>
        <field name="fecha"/>
        <field name="estado"/>
        <field name="idAsignatura"/>
        <field name="idAlumno"/>
      </tree>
    </field>
  </record>
</odoo>