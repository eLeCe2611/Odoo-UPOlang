<odoo>
  <record id="matriculas_list_action" model="ir.actions.act_window">
    <field name="name">Matriculas</field>
    <field name="res_model">upolang.matricula</field>
    <field name="view_mode">list,form</field>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">Crear la primera matricula</p>
    </field>
  </record>

  <record id="view_matricula_list" model="ir.ui.view">
    <field name="name">upolang.matricula.list</field>
    <field name="model">upolang.matricula</field>
    <field name="arch" type="xml">
      <tree>
        <field name="precio"/>
        <field name="fechaInicio"/>
        <field name="fechaFin"/>
        <field name="idAlumno"/>
        <field name="idAsignatura"/>
      </tree>
    </field>
  </record>
</odoo>