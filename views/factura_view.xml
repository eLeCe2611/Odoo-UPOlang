<odoo>
  <record id="facturas_list_action" model="ir.actions.act_window">
    <field name="name">Facturas</field>
    <field name="res_model">upolang.factura</field>
    <field name="view_mode">list,form</field>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">Crear la primera factura</p>
    </field>
  </record>

  <record id="view_factura_list" model="ir.ui.view">
    <field name="name">upolang.factura.list</field>
    <field name="model">upolang.factura</field>
    <field name="arch" type="xml">
      <tree>
        <field name="fecha"/>
        <field name="total"/>
        <field name="estado"/>
        <field name="idAlumno"/>
        <field name="idMatricula"/>
      </tree>
    </field>
  </record>
</odoo>