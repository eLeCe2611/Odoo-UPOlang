<odoo>
  <record id="profesores_list_action" model="ir.actions.act_window">
    <field name="name">Profesores</field>
    <field name="res_model">upolang.profesor</field>
    <field name="view_mode">list,form</field>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">Crear el primer profesor</p>
    </field>
  </record>

  <record id="view_profesor_list" model="ir.ui.view">
    <field name="name">upolang.profesor.list</field>
    <field name="model">upolang.profesor</field>
    <field name="arch" type="xml">
      <tree>
        <field name="name"/>
        <field name="telefono"/>
        <field name="correo"/>
      </tree>
    </field>
  </record>
</odoo>

