<odoo>
  <record id="empresas_list_action" model="ir.actions.act_window">
    <field name="name">Empresas</field>
    <field name="res_model">upolang.empresa</field>
    <field name="view_mode">list,form</field>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">Crear la primera empresa</p>
    </field>
  </record>

  <record id="view_empresa_list" model="ir.ui.view">
    <field name="name">upolang.empresa.list</field>
    <field name="model">upolang.empresa</field>
    <field name="arch" type="xml">
      <tree>
        <field name="name"/>
        <field name="telefono"/>
      </tree>
    </field>
  </record>
</odoo>