<odoo>
  <record id="tipoasignaturas_list_action" model="ir.actions.act_window">
    <field name="name">Tipoasignaturas</field>
    <field name="res_model">upolang.tipoasignatura</field>
    <field name="view_mode">list,form</field>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">Crear el primer tipo de asignatura</p>
    </field>
  </record>

  <record id="view_tipoasignatura_list" model="ir.ui.view">
    <field name="name">upolang.tipoasignatura.list</field>
    <field name="model">upolang.tipoasignatura</field>
    <field name="arch" type="xml">
      <tree>
        <field name="name"/>
      </tree>
    </field>
  </record>
</odoo>