<odoo>
  <record id="certificados_list_action" model="ir.actions.act_window">
    <field name="name">Certificados</field>
    <field name="res_model">upolang.certificado</field>
    <field name="view_mode">list,form</field>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">Crear el primer certificado</p>
    </field>
  </record>

  <record id="view_certificado_list" model="ir.ui.view">
    <field name="name">upolang.certificado.list</field>
    <field name="model">upolang.certificado</field>
    <field name="arch" type="xml">
      <tree>
        <field name="descripcion"/>
        <field name="nivel"/>
        <field name="fecha"/>
        <field name="idAsignatura"/>
        <field name="idAlumno"/>
      </tree>
    </field>
  </record>
</odoo>
