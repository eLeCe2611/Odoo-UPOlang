<odoo>
    <record id="aula_list_action" model="ir.actions.act_window">
        <field name="name">Aula</field>
        <field name="res_model">upolang.aula</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Crear el primer aula</p>
        </field>
    </record>

    <record id="upolang_aula_tree_view" model="ir.ui.view">
        <field name="name">upolang.aula.tree</field>
        <field name="model">upolang.aula</field>
        <field name="arch" type="xml">
            <tree string="Aulas">
                <field name="direccion"/>
                <field name="edificio"/>
                <field name="planta"/>
                <field name="numAula"/>
                <field name="capacidad"/>
            </tree>
        </field>
    </record>

    <record id="upolang_aula_form_view" model="ir.ui.view">
        <field name="name">upolang.aula.form</field>
        <field name="model">upolang.aula</field>
        <field name="arch" type="xml">
            <form string="Aula">
                <sheet>
                    <group>
                        <field name="direccion" placeholder="Direccion..."/>
                        <field name="edificio" placeholder="Edificio..."/>
                        <field name="planta" placeholder="Planta..."/>
                        <field name="numAula" placeholder="Número de Aula..."/>
                        <field name="capacidad" placeholder="Capacidad..."/>
                        <field name="idAsignaturas" widget="one2many" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>