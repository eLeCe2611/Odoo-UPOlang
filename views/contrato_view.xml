<odoo>
  <record id="contratos_list_action" model="ir.actions.act_window">
    <field name="name">Contratos</field>
    <field name="res_model">upolang.contrato</field>
    <field name="view_mode">list,form</field>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">Crear el primer contrato</p>
    </field>
  </record>

  <record id="view_contrato_list" model="ir.ui.view">
    <field name="name">upolang.contrato.list</field>
    <field name="model">upolang.contrato</field>
    <field name="arch" type="xml">
      <tree>
        <field name="sueldo"/>
        <field name="fechaInicio"/>
        <field name="fechaFin"/>
        <field name="detalles"/>
        <field name="idProfesor"/>
        <field name="idEmpresa"/>
        <field name="idAsignatura"/>
      </tree>
    </field>
  </record>
</odoo>