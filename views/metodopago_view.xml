<odoo>
  <record id="metodopagos_list_action" model="ir.actions.act_window">
    <field name="name">Metodopago</field>
    <field name="res_model">upolang.metodopago</field>
    <field name="view_mode">list,form</field>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">Crear el primer metodo de pago</p>
    </field>
  </record>

  <record id="view_metodopago_list" model="ir.ui.view">
    <field name="name">upolang.metodopago.list</field>
    <field name="model">upolang.metodopago</field>
    <field name="arch" type="xml">
      <tree>
        <field name="descripcion"/>
      </tree>
    </field>
  </record>
</odoo>